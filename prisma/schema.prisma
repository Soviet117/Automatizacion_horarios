generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model facultad {
  id_facultad  String    @id(map: "facultad_pk") @default(uuid()) @db.VarChar
  nom_facultad String    @db.VarChar
  carrera      carrera[]
}

model carrera {
  id_carrera   String         @id(map: "carrera_pk") @default(uuid()) @db.VarChar
  nom_carrera  String         @db.VarChar
  id_facultad  String         @db.VarChar
  facultad     facultad       @relation(fields: [id_facultad], references: [id_facultad], onDelete: Cascade, map: "carrera_facultad_fk")
  curso        curso[]
  plan_estudio plan_estudio[]
}

model plan_estudio {
  id_plan    String  @id(map: "plan_estudio_pk") @default(uuid()) @db.VarChar
  nom_plan   String  @db.VarChar
  id_carrera String  @db.VarChar
  curso      curso[]
  carrera    carrera @relation(fields: [id_carrera], references: [id_carrera], onDelete: Cascade, map: "plan_estudio_carrera_fk")
}

model ciclo {
  id_ciclo  Int     @id(map: "ciclo_pk")
  nom_ciclo String  @db.VarChar
  curso     curso[]
}

model tipo_sesion {
  id_tipo_sesion  String  @id(map: "tipo_sesion_pk") @default(uuid()) @db.VarChar
  nom_tipo_sesion String  @db.VarChar
  curso           curso[]
}

model curso {
  id_curso            String                @id(map: "curso_pk") @db.VarChar
  creditos            Int
  nom_curso           String                @db.VarChar
  id_carrera          String                @db.VarChar
  modalidad           String                @db.VarChar
  tipo_curso          String                @db.VarChar
  id_ciclo            Int
  alumnos             Int                   @default(0)
  horas_practicas     Int                   @default(0)
  horas_teoricas      Int                   @default(0)
  id_plan             String?               @db.VarChar
  id_usuario          String?               @db.VarChar
  asignacion          asignacion[]
  carrera             carrera               @relation(fields: [id_carrera], references: [id_carrera], onDelete: Cascade, map: "curso_carrera_fk")
  ciclo               ciclo                 @relation(fields: [id_ciclo], references: [id_ciclo], onDelete: Cascade, map: "curso_ciclo_fk")
  plan                plan_estudio?         @relation(fields: [id_plan], references: [id_plan], map: "curso_plan_estudio_fk")
  tipo_sesion         tipo_sesion           @relation(fields: [tipo_curso], references: [id_tipo_sesion], onDelete: Cascade, map: "curso_tipo_sesion_fk")
  usuario             usuario?              @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "curso_usuario_fk")
  competencia_docente competencia_docente[]
}

model docente {
  id_docente             String                   @id(map: "docente_pk") @db.VarChar
  dni_docente            String                   @db.VarChar
  nom_docente            String                   @db.VarChar
  ape_docente            String                   @db.VarChar
  nom_especialidad       String                   @db.VarChar
  id_usuario             String?                  @db.VarChar
  asignacion             asignacion[]
  disponibilidad_docente disponibilidad_docente[]
  usuario                usuario?                 @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "docente_usuario_fk")
  horario_sesion         horario_sesion[]
  competencia_docente    competencia_docente[]
}

model disponibilidad_docente {
  id_disponibilidad String         @id(map: "disponibilidad_docente_pk") @db.VarChar
  id_docente        String         @db.VarChar
  id_dia            Int
  id_bloque         Int
  bloque_horario    bloque_horario @relation(fields: [id_bloque], references: [id_bloque], onDelete: Cascade, map: "disponibilidad_docente_bloque_fk")
  dia_semana        dia_semana     @relation(fields: [id_dia], references: [id_dia], onDelete: Cascade, map: "disponibilidad_docente_dia_fk")
  docente           docente        @relation(fields: [id_docente], references: [id_docente], onDelete: Cascade, map: "disponibilidad_docente_docente_fk")

  @@unique([id_docente, id_dia, id_bloque], map: "disponibilidad_docente_uq")
  @@index([id_docente])
}

model aula {
  id_aula        String           @id(map: "aula_pk") @db.VarChar
  nom_aula       String           @db.VarChar
  id_tipo_aula   String           @db.VarChar
  capacidad      Int
  id_usuario     String?          @db.VarChar
  tipo_aula      tipo_aula        @relation(fields: [id_tipo_aula], references: [id_tipo_aula], onDelete: Cascade, map: "aula_tipo_aula_fk")
  usuario        usuario?         @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "aula_usuario_fk")
  horario_sesion horario_sesion[]
}

model tipo_aula {
  id_tipo_aula  String @id(map: "tipo_aula_pk") @db.VarChar
  nom_tipo_aula String @db.VarChar
  aula          aula[]
}

model periodo_academico {
  id_periodo     String           @id(map: "periodo_academico_pk") @db.VarChar
  nom_periodo    String           @db.VarChar
  activo         Boolean          @default(true)
  asignacion     asignacion[]
  horario_sesion horario_sesion[]
}

model dia_semana {
  id_dia                 Int                      @id(map: "dia_semana_pk")
  nom_dia                String                   @db.VarChar
  disponibilidad_docente disponibilidad_docente[]
  horario_sesion         horario_sesion[]
}

model bloque_horario {
  id_bloque              Int                      @id(map: "bloque_horario_pk")
  horario_inicio         String                   @db.VarChar
  horario_fin            String                   @db.VarChar
  disponibilidad_docente disponibilidad_docente[]
  horario_sesion         horario_sesion[]
}

model asignacion {
  id_asignacion  String            @id(map: "asignacion_pk") @db.VarChar
  id_docente     String            @db.VarChar
  id_curso       String            @db.VarChar
  id_periodo     String            @db.VarChar
  curso          curso             @relation(fields: [id_curso], references: [id_curso], onDelete: Cascade, map: "asignacion_curso_fk")
  docente        docente           @relation(fields: [id_docente], references: [id_docente], onDelete: Cascade, map: "asignacion_docente_fk")
  periodo        periodo_academico @relation(fields: [id_periodo], references: [id_periodo], onDelete: Cascade, map: "asignacion_periodo_fk")
  horario_sesion horario_sesion[]

  @@unique([id_docente, id_curso, id_periodo], map: "asignacion_uq")
  @@index([id_docente])
  @@index([id_curso])
  @@index([id_periodo])
}

model horario_sesion {
  id_horario     String            @id(map: "horario_sesion_pk") @db.VarChar
  id_asignacion  String            @db.VarChar
  id_docente     String            @db.VarChar
  id_periodo     String            @db.VarChar
  id_aula        String            @db.VarChar
  id_dia         Int
  id_bloque      Int
  tipo_sesion    String            @db.VarChar
  id_usuario     String?           @db.VarChar
  asignacion     asignacion        @relation(fields: [id_asignacion], references: [id_asignacion], onDelete: Cascade, map: "horario_sesion_asignacion_fk")
  aula           aula              @relation(fields: [id_aula], references: [id_aula], onDelete: Cascade, map: "horario_sesion_aula_fk")
  bloque_horario bloque_horario    @relation(fields: [id_bloque], references: [id_bloque], onDelete: Cascade, map: "horario_sesion_bloque_fk")
  dia_semana     dia_semana        @relation(fields: [id_dia], references: [id_dia], onDelete: Cascade, map: "horario_sesion_dia_fk")
  docente        docente           @relation(fields: [id_docente], references: [id_docente], onDelete: Cascade, map: "horario_sesion_docente_fk")
  periodo        periodo_academico @relation(fields: [id_periodo], references: [id_periodo], onDelete: Cascade, map: "horario_sesion_periodo_fk")
  usuario        usuario?          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, map: "horario_sesion_usuario_fk")

  @@unique([id_docente, id_dia, id_bloque, id_periodo], map: "horario_sesion_docente_uq")
  @@unique([id_aula, id_dia, id_bloque, id_periodo], map: "horario_sesion_aula_uq")
  @@unique([id_asignacion, id_dia, id_bloque, tipo_sesion], map: "horario_sesion_asignacion_uq")
  @@index([id_asignacion])
  @@index([id_aula])
  @@index([id_docente])
}

model usuario {
  id_usuario     String           @id(map: "usuario_pk") @default(uuid()) @db.VarChar
  email          String           @unique @db.VarChar
  password       String           @db.VarChar
  nombre         String           @db.VarChar
  aula           aula[]
  curso          curso[]
  docente        docente[]
  horario_sesion horario_sesion[]
}

model competencia_docente {
  id_docente String  @db.VarChar
  id_curso   String  @db.VarChar
  curso      curso   @relation(fields: [id_curso], references: [id_curso], onDelete: Cascade, map: "competencia_docente_curso_fk")
  docente    docente @relation(fields: [id_docente], references: [id_docente], onDelete: Cascade, map: "competencia_docente_docente_fk")

  @@id([id_docente, id_curso], map: "competencia_docente_pk")
  @@index([id_curso])
  @@index([id_docente])
}
